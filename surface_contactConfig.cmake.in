set(SURFACE_CONTACT_FOUND TRUE)
set(SURFACE_CONTACT_LIB_DIRS @INSTALL_DIR@/lib)
set(SURFACE_CONTACT_INCLUDE_DIRS @INSTALL_DIR@/include)

find_package(VTK REQUIRED)

if(VTK_FOUND)
    message(STATUS "VTK found: ${VTK_VERSION}")
    message(STATUS "VTK_INCLUDE_DIRS: ${VTK_INCLUDE_DIRS}")
    message(STATUS "VTK_LIBRARIES: ${VTK_LIBRARIES}")
else()
    message(FATAL_ERROR "VTK not found. Please check VTK_DIR.")
endif()

if(PCL_FOUND)
    message(STATUS "PCL found: ${PCL_VERSION}")
    message(STATUS "PCL_INCLUDE_DIRS: ${PCL_INCLUDE_DIRS}")
    message(STATUS "PCL_LIBRARIES: ${PCL_LIBRARIES}")
else()
    message(FATAL_ERROR "PCL not found. Please check PCL_DIR.")
endif()

include_directories(
  ${catkin_INCLUDE_DIRS}
  ${VTK_INCLUDE_DIRS}
)

set(SURFACE_CONTACT_INCLUDE_DIRS
    @INSTALL_DIR@/include)

set(SURFACE_CONTACT_LIBRARIES
    @INSTALL_DIR@/lib/libsurface_contact.so
    ${catkin_LIBRARIES}
    ${PCL_COMMON_LIBRARIES}
    ${PCL_SURFACE_LIBRARIES}
    ${VTK_LIBRARIES})